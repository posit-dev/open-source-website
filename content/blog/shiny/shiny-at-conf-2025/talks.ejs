          </div>
        </div>
        <div class="card-footer" style="background-color: var(--bs-body-bg);">
          <div class="d-flex flex-row gap-2 h-100 justify-content-start">
            <% if (talk.conf_link && talk.conf_link !=='~' ) { %>
              <a href="<%= talk.conf_link %>" class="btn btn-outline-primary btn-sm" target="_blank">
                <i class="bi bi-link-45deg me-1"></i>
                Conf Talk Page
              </a>
              <% } %>

                <% if (talk.slides_link && talk.slides_link !=='~' ) { %>
                  <a href="<%= talk.slides_link %>" class="btn btn-primary btn-sm" target="_blank">
                    <i class="bi bi-file-earmark-slides me-1"></i>
                    View Slides
                  </a>
                  <% } else { %>
                    <button class="btn btn-outline-secondary btn-sm" disabled>
                      <i class="bi bi-file-earmark-slides me-1"></i>
                      Slides Coming Soon
                    </button>
                    <% } %>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
</div>

<% if (items.length===0) { %>
  <div class="text-center py-5">
    <div class="mb-3">
      <i class="bi bi-calendar-x display-1 text-muted"></i>
    </div>
    <h4 class="text-muted">No talks available</h4>
    <p class="text-muted">Check back soon for upcoming talks and presentations.</p>
  </div>
<% } %>
```
